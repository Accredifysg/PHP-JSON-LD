{
    "name": "accredifysg/php-json-ld",
    "description": "A PHP implementation of the JSON-LD 1.1 specification.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/accredifysg/php-json-ld",
    "keywords": ["json-ld", "jsonld", "rdf", "linked-data", "semantic-web", "w3c"],
    "autoload": {
        "psr-4": {
            "Accredify\\JsonLd\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Accredify\\JsonLd\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.14",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "suggest": {
        "psr/http-client-implementation": "A PSR-18 client (e.g. guzzlehttp/guzzle) is required if you use HttpDocumentLoader for resolving remote @context URLs.",
        "psr/http-factory-implementation": "A PSR-17 request factory (e.g. guzzlehttp/psr7) is required if you use HttpDocumentLoader."
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "lint": [
            "@php vendor/bin/pint",
            "@php vendor/bin/phpstan analyse --no-progress"
        ],
        "lint:check": [
            "@php vendor/bin/pint --test",
            "@php vendor/bin/phpstan analyse --no-progress"
        ],
        "test": [
            "@php vendor/bin/pest --testsuite=Unit"
        ],
        "test:coverage": [
            "@php vendor/bin/pest --testsuite=Unit --coverage"
        ],
        "test:w3c": [
            "@php vendor/bin/pest --testsuite=W3C"
        ],
        "test:all": [
            "@php vendor/bin/pest"
        ]
    }
}
